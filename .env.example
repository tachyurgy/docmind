# Database connection string (PostgreSQL with pgvector extension)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docmind

# OpenAI API key for embeddings and fallback generation
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API key for primary generation (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Embedding configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Chunking configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Upload limits
MAX_UPLOAD_SIZE_MB=50

# Optional API key for authenticating requests (leave blank to disable auth)
API_KEY=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Log level
LOG_LEVEL=INFO
