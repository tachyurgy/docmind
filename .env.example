# Local dev database (default)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docmind

# Remote database (Supabase rag-apps project, schema: docmind)
# The dm_app role has search_path pinned to the docmind schema, so all
# tables/indexes created by alembic migrations land there automatically.
# pgvector is already installed at the database level.
#
# Note for asyncpg + pgbouncer transaction mode (port 6543): set
#   statement_cache_size=0
# in create_async_engine connect_args, or use the direct connection
# on port 5432 (IPv6-only on Supabase free tier).
#
# DATABASE_URL=postgresql+asyncpg://dm_app.lndmgmmtsnysihtfcvnj:REPLACE_WITH_DM_PW@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# OpenAI API key for embeddings and fallback generation
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API key for primary generation (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Embedding configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Chunking configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Upload limits
MAX_UPLOAD_SIZE_MB=50

# Optional API key for authenticating requests (leave blank to disable auth)
API_KEY=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Log level
LOG_LEVEL=INFO
